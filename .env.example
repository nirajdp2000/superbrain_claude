# ─────────────────────────────────────────────────────────
# Superbrain India — Environment Variables
# ─────────────────────────────────────────────────────────
# For Netlify, set these in Site settings → Environment variables.
# Do NOT commit secrets to git.
# ─────────────────────────────────────────────────────────

# ── Server ──
PORT=3210

# Public site URL (used to derive OAuth redirect URI and CORS origin).
# On Netlify this is auto-provided via URL/DEPLOY_PRIME_URL; override only if needed.
SUPERBRAIN_PUBLIC_SITE_URL=https://your-site.netlify.app

# Comma-separated list of origins allowed to call the API.
# When empty, only same-origin requests are allowed (no wildcard).
SUPERBRAIN_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-site.netlify.app

# Required for the /api/upstox/token admin endpoint (manual token upload).
# Generate with: openssl rand -hex 32
SUPERBRAIN_ADMIN_TOKEN=change-me

# ── Token storage ──
# Local dev only. On Netlify, tokens are stored in Netlify Blobs automatically.
SUPERBRAIN_TOKEN_DB_PATH=./data/upstox-token-store.json

# Netlify Blobs store name (default: superbrain-upstox)
SUPERBRAIN_TOKEN_BLOB_STORE=superbrain-upstox

# ── HTTP client ──
SUPERBRAIN_HTTP_TIMEOUT_MS=9000

# Optional: share an Upstox connection with another Superbrain instance.
# Leave empty on Netlify.
SUPERBRAIN_UPSTOX_PROXY_URL=

# ── Upstox OAuth (required for live quotes) ──
# Get these from https://account.upstox.com/developer/apps
UPSTOX_CLIENT_ID=
UPSTOX_CLIENT_SECRET=
UPSTOX_REDIRECT_URI=https://your-site.netlify.app/api/upstox/callback

# Optional seed tokens for first boot. Prefer the OAuth flow over seeding.
UPSTOX_ACCESS_TOKEN=
UPSTOX_REFRESH_TOKEN=
